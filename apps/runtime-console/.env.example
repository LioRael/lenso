# Runtime Console mode:
# - mock keeps the UI fully local with seeded data.
# - api switches core runtime views to the configured backend.
VITE_RUNTIME_CONSOLE_MODE=mock

# Used when VITE_RUNTIME_CONSOLE_MODE=api.
VITE_API_BASE_URL=http://localhost:3000

# Development service token used for local API calls in API mode.
VITE_API_AUTH_TOKEN=dev-service:admin:remote_crm.contacts.read,remote_crm.contacts.sync
