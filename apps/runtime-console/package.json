{
  "name": "@lenso/runtime-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "format": "ultracite fix --unsafe",
    "format:check": "oxfmt --check .",
    "lint": "ultracite check --deny-warnings",
    "check": "pnpm check:console-packages && ultracite check --deny-warnings && pnpm test && pnpm typecheck && pnpm build",
    "check:console-packages": "node scripts/check-console-packages.mjs",
    "build": "tsc -b && vite build",
    "test": "vitest run src packages/story-console/src packages/identity-console/src packages/console-package-api/src",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@gsap/react": "^2.1.2",
    "@lenso/identity-console": "workspace:*",
    "@lenso/runtime-console-api": "workspace:*",
    "@lenso/story-console": "workspace:*",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.99.0",
    "@vitejs/plugin-react": "^6.0.2",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "ky": "^2.0.2",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.8.1",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
