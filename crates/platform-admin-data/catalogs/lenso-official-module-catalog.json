{
  "version": 1,
  "modules": [
    {
      "name": "auth",
      "version": "0.1.4",
      "source": "linked",
      "manifestReference": "builtin:auth",
      "summary": "Official linked authentication anchor for users, sessions, and actor resolution",
      "capabilities": ["auth.users.read"],
      "consolePackages": [
        {
          "packageName": "@lenso/auth-console",
          "exportName": "authConsoleModule",
          "bundleUrl": "https://cdn.jsdelivr.net/npm/@lenso/auth-console@0.1.3/dist/auth-console.js",
          "entry": "/console/extensions/auth/auth-console.js",
          "hostApi": "1",
          "route": "/data/auth/sessions",
          "requiredCapabilities": ["auth.users.read"],
          "styles": [
            "https://cdn.jsdelivr.net/npm/@lenso/auth-console@0.1.3/dist/auth-console.css"
          ],
          "version": "0.1.3"
        }
      ]
    },
    {
      "name": "auth-oauth",
      "version": "0.1.0",
      "source": "linked",
      "manifestReference": "builtin:auth-oauth",
      "summary": "Official linked OAuth client substrate for provider login flows",
      "capabilities": [],
      "dependencies": ["auth"],
      "consolePackages": [
        {
          "packageName": "@lenso/auth-provider-console",
          "exportName": "authProviderConsoleModule",
          "bundleUrl": "https://cdn.jsdelivr.net/npm/@lenso/auth-provider-console@0.1.0/dist/auth-provider-console.js",
          "entry": "/console/extensions/auth-oauth/auth-provider-console.js",
          "hostApi": "1",
          "route": "/data/auth/providers",
          "requiredCapabilities": [],
          "styles": [
            "https://cdn.jsdelivr.net/npm/@lenso/auth-provider-console@0.1.0/dist/auth-provider-console.css"
          ],
          "version": "0.1.0"
        }
      ]
    },
    {
      "name": "auth-anonymous",
      "version": "0.1.0",
      "source": "linked",
      "manifestReference": "builtin:auth-anonymous",
      "summary": "Official linked anonymous authentication provider for guest sessions and later account upgrade",
      "capabilities": [],
      "dependencies": ["auth"]
    },
    {
      "name": "auth-password",
      "version": "0.1.1",
      "source": "linked",
      "manifestReference": "builtin:auth-password",
      "summary": "Official linked password authentication provider for registration and login",
      "capabilities": [],
      "dependencies": ["auth"]
    },
    {
      "name": "auth-phone",
      "version": "0.1.0",
