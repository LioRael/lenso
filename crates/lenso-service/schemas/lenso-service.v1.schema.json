{
  "$id": "https://contracts.lenso.local/services/lenso-service.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LensoServiceContract",
  "type": "object",
  "required": ["name", "modules"],
  "additionalProperties": true,
  "properties": {
    "protocol": {
      "type": "string",
      "const": "lenso.service.v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "config": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/configField"
      }
    },
    "env": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/envField"
      }
    },
    "requiredEnv": {
      "$ref": "#/$defs/stringList"
    },
    "required_env": {
      "$ref": "#/$defs/stringList"
    },
    "health": {
      "$ref": "#/$defs/health"
    },
    "localProcess": {
      "$ref": "#/$defs/localProcess"
    },
    "local_process": {
      "$ref": "#/$defs/localProcess"
    },
    "install": {
      "$ref": "#/$defs/install"
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/module"
      }
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "vendor": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "homepage": {
          "type": "string"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "remoteProtocolVersion": {
          "type": "string"
        },
        "remote_protocol_version": {
          "type": "string"
        },
        "requiredHostFeatures": {
          "$ref": "#/$defs/stringList"
        },
        "required_host_features": {
          "$ref": "#/$defs/stringList"
        },
        "consolePackageApi": {
          "type": "string"
        },
        "console_package_api": {
          "type": "string"
        },
        "sdkLanguage": {
          "type": "string"
        },
        "sdk_language": {
          "type": "string"
        },
        "sdkVersion": {
          "type": "string"
        },
        "sdk_version": {
          "type": "string"
        }
      }
    },
    "configField": {
      "type": "object",
      "required": ["key"],
      "additionalProperties": true,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "defaultValue": true,
        "secret": {
          "type": "boolean"
        }
      }
    },
    "envField": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "example": {
          "type": "string"
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "manifestUrl": {
          "type": "string"
        },
        "readyUrl": {
          "type": "string"
        },
        "livenessUrl": {
          "type": "string"
        },
        "statusUrl": {
          "type": "string"
        }
      }
    },
    "localProcess": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": true,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "autoStart": {
          "type": "boolean"
        },
        "readyTimeoutMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "services": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/managedService"
          }
        },
        "commands": {
          "type": "array"
        }
      }
    },
    "managedService": {
      "type": "object",
      "required": ["name", "command"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "cwd": {
          "type": "string"
        },
        "readyUrl": {
          "type": "string"
        },
        "readyTimeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "autoStart": {
          "type": "boolean"
        }
      }
    },
    "module": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "capabilities": {
          "$ref": "#/$defs/stringList"
        },
        "dependencies": {
          "$ref": "#/$defs/stringList"
        },
        "console": {
          "type": "array"
        }
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
