{
  "$id": "https://contracts.lenso.local/services/lenso-service.v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LensoAutonomousServiceContract",
  "type": "object",
  "required": ["protocol", "serviceId", "workloads", "tenancyMode", "operatingRegions"],
  "additionalProperties": false,
  "properties": {
    "protocol": { "const": "lenso.service.v2" },
    "serviceId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "workloads": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/workload" }
    },
    "modules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "stores": {
      "type": "array",
      "items": { "$ref": "#/$defs/store" }
    },
    "tenancyMode": { "enum": ["none", "optional", "required"] },
    "operatingRegions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "workload": {
      "type": "object",
      "required": ["workloadId", "serviceId", "role"],
      "additionalProperties": false,
      "properties": {
        "workloadId": { "type": "string", "minLength": 1 },
        "serviceId": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 }
      }
    },
    "store": {
      "type": "object",
      "required": ["storeId", "serviceId"],
      "additionalProperties": false,
      "properties": {
        "storeId": { "type": "string", "minLength": 1 },
        "serviceId": { "type": "string", "minLength": 1 }
      }
    }
  }
}
