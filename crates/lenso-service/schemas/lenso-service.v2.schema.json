{
  "$id": "https://contracts.lenso.local/services/lenso-service.v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LensoAutonomousServiceContract",
  "type": "object",
  "required": ["protocol", "serviceId", "workloads", "tenancyMode", "operatingRegions"],
  "additionalProperties": false,
  "properties": {
    "protocol": { "const": "lenso.service.v2" },
    "serviceId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "workloads": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/workload" }
    },
    "modules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "stores": {
      "type": "array",
      "items": { "$ref": "#/$defs/store" }
    },
    "serviceContracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/serviceContract" }
    },
    "eventContracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/eventContract" }
    },
    "configContract": { "$ref": "#/$defs/configContract" },
    "reliabilityContract": { "$ref": "#/$defs/reliabilityContract" },
    "tenancyMode": { "enum": ["none", "optional", "required"] },
    "operatingRegions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "workload": {
      "type": "object",
      "required": ["workloadId", "serviceId", "role"],
      "additionalProperties": false,
      "properties": {
        "workloadId": { "type": "string", "minLength": 1 },
        "serviceId": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 }
      }
    },
    "store": {
      "type": "object",
      "required": ["storeId", "serviceId"],
      "additionalProperties": false,
      "properties": {
        "storeId": { "type": "string", "minLength": 1 },
        "serviceId": { "type": "string", "minLength": 1 }
      }
    },
    "serviceContract": {
      "type": "object",
      "required": ["contractId", "moduleId", "version", "tenancyMode", "artifact", "context"],
      "additionalProperties": false,
      "properties": {
        "contractId": { "type": "string", "minLength": 1 },
        "moduleId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "tenancyMode": { "enum": ["none", "optional", "required"] },
        "artifact": { "$ref": "#/$defs/serviceArtifact" },
        "context": { "$ref": "#/$defs/contextRequirements" }
      }
    },
    "eventContract": {
      "type": "object",
      "required": ["contractId", "moduleId", "version", "tenancyMode", "artifact", "context"],
      "additionalProperties": false,
      "properties": {
        "contractId": { "type": "string", "minLength": 1 },
        "moduleId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "tenancyMode": { "enum": ["none", "optional", "required"] },
        "artifact": { "$ref": "#/$defs/eventArtifact" },
        "context": { "$ref": "#/$defs/contextRequirements" }
      }
    },
    "serviceArtifact": {
      "type": "object",
      "required": ["format", "path"],
      "additionalProperties": false,
      "properties": {
        "format": { "enum": ["openapi", "protobuf"] },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "eventArtifact": {
      "type": "object",
      "required": ["format", "path"],
      "additionalProperties": false,
      "properties": {
        "format": { "enum": ["json_schema", "protobuf"] },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "contextRequirements": {
      "type": "object",
      "required": ["protocol", "required"],
      "additionalProperties": false,
      "properties": {
        "protocol": { "const": "lenso.context.v1" },
        "required": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["story", "trace", "service_principal", "delegated_actor", "tenant", "deadline", "idempotency_key", "causation", "region"] }
        }
      }
    },
    "schemaArtifact": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": { "path": { "type": "string", "minLength": 1 } }
    },
    "configContract": {
      "type": "object",
      "required": ["contractId", "version", "artifact", "fields"],
      "additionalProperties": false,
      "properties": {
        "contractId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "artifact": { "$ref": "#/$defs/schemaArtifact" },
        "fields": { "type": "array", "items": { "$ref": "#/$defs/configField" } }
      }
    },
    "configField": {
      "type": "object",
      "required": ["path", "shape", "sensitive", "scope", "mutability", "activation"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "shape": { "type": "string", "minLength": 1 },
        "sensitive": { "type": "boolean" },
        "scope": { "enum": ["service", "region", "tenant"] },
        "mutability": { "enum": ["immutable", "mutable"] },
        "activation": { "enum": ["hot", "restart"] }
      }
    },
    "reliabilityContract": {
      "type": "object",
      "required": ["contractId", "version", "artifact", "profile", "overrides", "availabilityTarget", "latencyTargetMs", "dependencyCriticality", "healthSemantics", "degradedModes", "degradedModeByDependency", "backlogLimit", "errorBudget", "rolloutSafety"],
      "additionalProperties": false,
      "properties": {
        "contractId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "artifact": { "$ref": "#/$defs/schemaArtifact" },
        "profile": { "enum": ["development", "standard", "critical"] },
        "overrides": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "queueBacklogLimit": { "type": "integer", "minimum": 0 },
            "workflowBacklogLimit": { "type": "integer", "minimum": 0 },
            "timerLagLimitMs": { "type": "integer", "minimum": 0 },
            "retryExhaustionLimit": { "type": "integer", "minimum": 0 },
            "compensationPressureLimit": { "type": "integer", "minimum": 0 },
            "errorBudgetConsumedLimitBasisPoints": { "type": "integer", "minimum": 0, "maximum": 10000 },
            "readiness": { "enum": ["serving", "healthy"] },
            "liveness": { "enum": ["process_running", "runtime_operational"] }
          }
        },
        "availabilityTarget": { "type": "string", "pattern": "^(100(?:\\.0{1,2})?|(?:[0-9]{1,2})(?:\\.[0-9]{1,2})?)%$" },
        "latencyTargetMs": { "type": "integer", "minimum": 0 },
        "dependencyCriticality": { "type": "object", "additionalProperties": { "enum": ["critical", "degradable", "optional"] } },
        "healthSemantics": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "degradedModes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "degradedModeByDependency": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1 } },
        "backlogLimit": { "type": "integer", "minimum": 0 },
        "errorBudget": { "type": "string", "minLength": 1 },
        "rolloutSafety": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
