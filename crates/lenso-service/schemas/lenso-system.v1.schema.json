{
  "$id": "https://contracts.lenso.local/services/lenso-system.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LensoServiceSystem",
  "type": "object",
  "required": ["protocol", "name"],
  "additionalProperties": true,
  "properties": {
    "protocol": {
      "type": "string",
      "const": "lenso.system.v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "services": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/service"
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/module"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependency"
      }
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "required": ["name", "target"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "manifest": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "module": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "installTo": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dependency": {
      "type": "object",
      "required": ["from", "capability"],
      "additionalProperties": true,
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "capability": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
