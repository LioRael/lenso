{
  "name": "@lenso/ts-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Lenso's generated HTTP API.",
  "type": "module",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LioRael/lenso.git",
    "directory": "packages/ts-sdk"
  },
  "bugs": {
    "url": "https://github.com/LioRael/lenso/issues"
  },
  "homepage": "https://github.com/LioRael/lenso#readme",
  "keywords": [
    "lenso",
    "typescript",
    "sdk",
    "openapi",
    "runtime-console"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "generate": "cargo run -p generate-ts-sdk",
    "check": "pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
