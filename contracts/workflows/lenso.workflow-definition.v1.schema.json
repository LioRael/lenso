{
  "$defs": {
    "compensation": {
      "additionalProperties": false,
      "properties": {
        "completionContract": {
          "$ref": "#/$defs/dataContract"
        },
        "contract": {
          "$ref": "#/$defs/dataContract"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "order": {
          "maximum": 2147483647,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "name",
        "order",
        "contract",
        "completionContract"
      ],
      "type": "object"
    },
    "dataContract": {
      "additionalProperties": false,
      "properties": {
        "contractId": {
          "minLength": 1,
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "contractId",
        "version"
      ],
      "type": "object"
    },
    "retryPolicy": {
      "additionalProperties": false,
      "properties": {
        "delaysMs": {
          "items": {
            "maximum": 9223372036854775807,
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        },
        "maxAttempts": {
          "maximum": 2147483647,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "maxAttempts",
        "delaysMs"
      ],
      "type": "object"
    },
    "step": {
      "additionalProperties": false,
      "properties": {
        "compensation": {
          "$ref": "#/$defs/compensation"
        },
        "displayName": {
          "minLength": 1,
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "retryPolicy": {
          "$ref": "#/$defs/retryPolicy"
        },
        "timeoutMs": {
          "maximum": 9223372036854775807,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    }
  },
  "$id": "https://contracts.lenso.local/workflows/lenso.workflow-definition.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "inputContract": {
      "$ref": "#/$defs/dataContract"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "owner": {
      "minLength": 1,
      "type": "string"
    },
    "protocol": {
      "const": "lenso.workflow-definition.v1"
    },
    "resultContract": {
      "$ref": "#/$defs/dataContract"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/step"
      },
      "minItems": 1,
      "type": "array"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "protocol",
    "owner",
    "name",
    "version",
    "inputContract",
    "resultContract",
    "steps"
  ],
  "title": "LensoWorkflowDefinition",
  "type": "object"
}
