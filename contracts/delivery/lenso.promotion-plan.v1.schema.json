  "required": [
    "protocol",
    "planId",
    "planDigest",
    "releaseId",
    "releaseDigest",
    "workloadDigests",
    "sourceEnvironment",
    "targetEnvironment",
    "sourceEnvironmentRevision",
    "targetEnvironmentRevision",
    "sourceVerificationId",
    "sourceVerificationDigest",
    "policyEvidenceId",
    "policyEvidenceDigest",
    "configRevisionId",
    "secretReferenceIds",
    "targetDeployment",
    "targetGateway",
    "sourceTopologyDigest",
    "targetTopologyDigest",
    "evidenceReferences",
    "freshnessHorizonRevision",
    "effects"
  ],
  "title": "PromotionPlan",
  "type": "object"
}
