{
  "$defs": {
    "CompatibilityCategory": {
      "enum": [
        "safe",
        "needs_attention",
        "breaking",
        "blocked"
      ],
      "type": "string"
    },
    "ExtractionConsumerCompatibilityEvidence": {
      "properties": {
        "classification": {
          "$ref": "#/$defs/CompatibilityCategory"
        },
        "consumerId": {
          "type": "string"
        },
        "contractId": {
          "type": "string"
        },
        "evidenceReferences": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "nextAction": {
          "type": "string"
        }
      },
      "required": [
        "consumerId",
        "contractId",
        "classification",
        "nextAction"
      ],
      "type": "object"
    },
    "ExtractionContractDirection": {
      "enum": [
        "provides",
        "consumes"
      ],
      "type": "string"
    },
    "ExtractionContractEvidence": {
      "properties": {
        "contractId": {
          "type": [
            "string",
            "null"
          ]
        },
        "direction": {
          "$ref": "#/$defs/ExtractionContractDirection"
        },
        "evidenceReferences": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "kind": {
          "$ref": "#/$defs/ExtractionContractKind"
        },
        "status": {
          "$ref": "#/$defs/ExtractionEvidenceStatus"
        },
        "subject": {
          "type": "string"
        }
      },
      "required": [
        "subject",
        "kind",
        "direction",
        "status"
      ],
      "type": "object"
    },
    "ExtractionContractKind": {
      "enum": [
        "service",
        "event"
      ],
      "type": "string"
    },
    "ExtractionCursorEvidence": {
      "properties": {
        "column": {
          "type": "string"
        },
        "evidenceReferences": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "highWaterMark": {
          "type": "string"
        },
        "trustworthy": {
          "type": "boolean"
        }
      },
      "required": [
        "column",
        "highWaterMark",
        "trustworthy"
      ],
      "type": "object"
    },
    "ExtractionDataAccessEvidence": {
      "properties": {
        "access": {
          "$ref": "#/$defs/ExtractionDataAccessKind"
        },
        "accessorModule": {
          "type": "string"
        },
        "evidenceReferences": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "source": {
          "$ref": "#/$defs/ExtractionDataEvidenceSource"
        },
        "table": {
          "type": "string"
        }
      },
      "required": [
        "accessorModule",
        "table",
        "access",
        "source"
      ],
      "type": "object"
    },
    "ExtractionDataAccessKind": {
      "enum": [
        "read",
        "write",
        "read_write"
      ],
      "type": "string"
    },
    "ExtractionDataEvidenceSource": {
      "oneOf": [
        {
          "properties": {
            "kind": {
              "const": "static_declaration",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "live_store_observation",
              "type": "string"
            },
            "observationId": {
              "type": "string"
            },
            "readOnly": {
              "type": "boolean"
            },
            "store": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "observationId",
            "store",
            "readOnly"
          ],
          "type": "object"
        }
      ]
    },
    "ExtractionDataTableEvidence": {
      "properties": {
        "cursor": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExtractionCursorEvidence"
            },
            {
              "type": "null"
            }
          ]
        },
        "evidenceReferences": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ownerModule": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "$ref": "#/$defs/ExtractionDataEvidenceSource"
        },
        "table": {
          "type": "string"
        },
        "volume": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExtractionDataVolumeEvidence"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "table",
        "source"
      ],
      "type": "object"
    },
    "ExtractionDataVolumeEvidence": {
      "properties": {
        "approximateBytes": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "approximateRows": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "evidenceReferences": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "ExtractionEvidenceStatus": {
      "enum": [
        "present",
        "missing",
        "ambiguous"
      ],
      "type": "string"
    },
    "ExtractionMigrationEvidence": {
      "properties": {
        "evidenceReferences": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "migration": {
          "type": "string"
        },
        "ownerModule": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "$ref": "#/$defs/ExtractionDataEvidenceSource"
        }
      },
      "required": [
        "migration",
        "source"
      ],
      "type": "object"
    },
    "ExtractionReadinessEffects": {
      "properties": {
        "changesAuthority": {
          "const": false,
          "type": "boolean"
        },
        "movesData": {
          "const": false,
          "type": "boolean"
        },
        "startsWorkloads": {
          "const": false,
          "type": "boolean"
        },
        "writesRepositoryFiles": {
          "const": false,
          "type": "boolean"
        }
      },
      "required": [
        "writesRepositoryFiles",
        "startsWorkloads",
        "movesData",
        "changesAuthority"
      ],
      "type": "object"
    },
    "ExtractionReadinessFinding": {
      "properties": {
        "classification": {
          "$ref": "#/$defs/CompatibilityCategory"
        },
        "code": {
          "$ref": "#/$defs/ExtractionReadinessIssueCode"
        },
        "evidenceReferences": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "message": {
          "type": "string"
        },
        "nextActions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "subject": {
          "type": "string"
        }
      },
      "required": [
        "classification",
        "code",
        "subject",
        "message",
        "evidenceReferences",
        "nextActions"
      ],
      "type": "object"
    },
    "ExtractionReadinessIssueCode": {
      "enum": [
        "active_consumer_blocked",
        "active_consumer_breaking",
        "active_consumer_compatibility_missing",
        "active_consumer_evidence_ambiguous",
        "active_consumer_needs_attention",
        "admin_surface_present",
        "boundary_clean",
        "boundary_evidence_ambiguous",
        "boundary_evidence_incomplete",
        "boundary_evidence_missing",
        "boundary_evidence_target_mismatch",
        "console_surface_present",
        "consumers_compatible",
        "contract_evidence_ambiguous",
        "contract_evidence_missing",
        "contract_identity_mismatch",
        "contracts_complete",
        "cross_module_table_access",
        "cross_module_import",
        "data_volume_large",
        "extraction_cursor_missing",
        "extraction_cursor_usable",
        "in_process_boundary_call",
        "live_store_observation_not_read_only",
        "live_store_observation_present",
        "manifest_invalid",
        "manifest_needs_attention",
        "migration_ownership_unresolved",
        "required_event_contract_missing",
        "required_service_contract_missing",
        "runtime_surface_present",
        "service_data_evidence_incomplete",
        "service_data_evidence_missing",
        "service_data_ready",
        "story_surface_present",
        "system_evidence_invalid",
        "table_ownership_unresolved",
        "target_module_missing",
        "target_module_not_linked",
        "transaction_boundary_unresolved",
        "transaction_spans_service_boundary",
        "workflow_surface_present"
      ],
      "type": "string"
    },
    "ExtractionReadinessSurfaceSummary": {
      "properties": {
        "admin": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "console": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "eventHandlers": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "httpRoutes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "runtimeFunctions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "schedules": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "stories": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "workflows": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "ExtractionServiceDataEvidence": {
      "properties": {
        "accessPaths": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExtractionDataAccessEvidence"
          },
          "type": "array"
        },
        "complete": {
          "type": "boolean"
        },
        "evidenceReferences": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "migrations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExtractionMigrationEvidence"
          },
          "type": "array"
        },
        "tables": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExtractionDataTableEvidence"
          },
          "type": "array"
        },
        "transactions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExtractionTransactionEvidence"
          },
          "type": "array"
        }
      },
      "required": [
        "complete"
      ],
      "type": "object"
    },
    "ExtractionTransactionEvidence": {
      "properties": {
        "evidenceReferences": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "participatingModules": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "source": {
          "$ref": "#/$defs/ExtractionDataEvidenceSource"
        },
        "transaction": {
          "type": "string"
        }
      },
      "required": [
        "transaction",
        "source"
      ],
      "type": "object"
    }
  },
  "$id": "https://contracts.lenso.local/extraction/lenso.extraction-readiness-report.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "activeConsumers": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ExtractionConsumerCompatibilityEvidence"
      },
      "type": "array"
    },
    "analyzerVersion": {
      "const": "lenso.extraction-readiness.v2",
      "type": "string"
    },
    "classification": {
      "$ref": "#/$defs/CompatibilityCategory"
    },
    "contractEvidence": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ExtractionContractEvidence"
      },
      "type": "array"
    },
    "effects": {
      "$ref": "#/$defs/ExtractionReadinessEffects"
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/ExtractionReadinessFinding"
      },
      "type": "array"
    },
    "issueCodes": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ExtractionReadinessIssueCode"
      },
      "type": "array",
      "uniqueItems": true
    },
    "protocol": {
      "const": "lenso.extraction-readiness-report.v1",
      "type": "string"
    },
    "ready": {
      "type": "boolean"
    },
    "serviceData": {
      "$ref": "#/$defs/ExtractionServiceDataEvidence",
      "default": {
        "accessPaths": [],
        "complete": false,
        "evidenceReferences": [],
        "migrations": [],
        "tables": [],
        "transactions": []
      }
    },
    "surfaces": {
      "$ref": "#/$defs/ExtractionReadinessSurfaceSummary"
    },
    "systemId": {
      "type": [
        "string",
        "null"
      ]
    },
    "targetModule": {
      "type": "string"
    },
    "targetOwner": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "protocol",
    "analyzerVersion",
    "targetModule",
    "classification",
    "ready",
    "surfaces",
    "findings",
    "effects"
  ],
  "title": "Lenso Extraction Readiness Report v1",
  "type": "object"
}
