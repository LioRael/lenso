      "items": {
        "$ref": "#/$defs/store"
      },
      "type": "array"
    },
    "tenancyMode": {
      "enum": [
        "none",
        "optional",
        "required"
      ]
    },
    "version": {
      "minLength": 1,
      "type": "string"
    },
    "workloads": {
      "items": {
        "$ref": "#/$defs/workload"
      },
      "minItems": 1,
      "type": "array"
    }
